{
  "name": "foundry",
  "version": "0.1.0",
  "description": "Autonomous business intelligence platform for SaaS founders",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias && cp -r src/public dist/public",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "migrate": "tsx src/cli/index.ts db:migrate",
    "seed": "tsx src/cli/index.ts db:seed",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@clerk/clerk-sdk-node": "^4.13.0",
    "@hono/node-server": "^1.19.9",
    "@libsql/client": "^0.5.0",
    "commander": "^12.0.0",
    "cron": "^3.1.0",
    "hono": "^4.0.0",
    "nanoid": "^5.0.0",
    "resend": "^3.0.0",
    "stripe": "^14.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
