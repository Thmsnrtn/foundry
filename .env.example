# =============================================================================
# FOUNDRY — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running.

# Database (Turso)
# Provision at https://turso.tech — create a database, get URL and auth token
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Authentication (Clerk)
# Create app at https://clerk.com — get keys from dashboard
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# GitHub OAuth
# Create OAuth App at https://github.com/settings/developers
# Callback URL: {APP_URL}/onboarding/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# AI (Anthropic)
# Get API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
# Create account at https://resend.com — verify domain
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=foundry@yourdomain.com

# Payments (Stripe)
# Create account at https://stripe.com — create products and prices
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FOUNDING_COHORT_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# Ecosystem Integration
# Shared secret for internal API routes between Foundry, Koldly, AcreOS, Apex Micro
ECOSYSTEM_SERVICE_KEY=your-ecosystem-service-key
KOLDLY_INTERNAL_API_URL=https://koldly.yourdomain.com

# Application
APP_URL=http://localhost:8080
NODE_ENV=development
